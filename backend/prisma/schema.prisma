// This is your Prisma schema file (Prisma v7)

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  OFFICER
  ADMIN
}

enum FineStatus {
  PENDING
  PAID
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  phone     String?
  nic       String?  @unique
  dlNo      String?  @unique
  districtId Int?
  isActive  Boolean  @default(true)
  refreshToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  district  District? @relation("UserDistrict", fields: [districtId], references: [id])
  officer   Officer?
  savedCards SavedCard[]
}

model District {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  officers Officer[]
  users    User[]    @relation("UserDistrict")
}

model Officer {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  badgeNo    String   @unique
  phone      String
  districtId Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  district   District @relation(fields: [districtId], references: [id])
  fines      Fine[]
}

model FineCategory {
  id          Int    @id @default(autoincrement())
  name        String @unique
  description String?
  amount      Float
  isActive    Boolean @default(true)
  fines       Fine[]
}

model Fine {
  id          Int        @id @default(autoincrement())
  referenceNo String     @unique
  vehicleNo   String
  driverName  String
  driverPhone String?
  driverNIC   String?
  driverDL    String?
  driverEmail String?
  offenseDate DateTime
  location    String
  categoryId  Int
  officerId   Int
  status      FineStatus @default(PENDING)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  category    FineCategory @relation(fields: [categoryId], references: [id])
  officer     Officer      @relation(fields: [officerId], references: [id])
  payment     Payment?
}

model Payment {
  id            Int      @id @default(autoincrement())
  fineId        Int      @unique
  amount        Float
  payerName     String
  payerPhone    String
  paymentMethod String   @default("ONLINE")
  status        String   @default("SUCCESS")
  transactionId String?  @unique
  receiptNo     String   @unique
  paidAt        DateTime @default(now())
  fine          Fine     @relation(fields: [fineId], references: [id])
  smsLogs       SMSLog[]
}

model SMSLog {
  id        Int      @id @default(autoincrement())
  paymentId Int
  officerPhone String
  message   String
  status    String
  sid       String?
  sentAt    DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id])
}

model SavedCard {
  id             Int      @id @default(autoincrement())
  userId         Int
  cardholderName String
  cardNumber     String   // Masked card number: e.g. **** **** **** 4242
  expiry         String   // MM/YY
  brand          String   // Visa, MasterCard, etc.
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
